# LLM providers
OPENAI_API_KEY=INSERT_YOUR_OPENAI_API_KEY_HERE
OPENAI_MODEL=gpt-4.1
OPENAI_BASE_URL=https://api.openai.com/v1

OPENROUTER_API_KEY=INSERT_YOUR_OPENROUTER_API_KEY_HERE
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_TITLE=Deep Factual Research Engine
OPENROUTER_HTTP_REFERER=http://localhost:8080

# Search provider
SEARCH_API_KEY=INSERT_YOUR_SEARCH_API_KEY_HERE
SEARCH_API_PROVIDER=serper
SERPER_API_BASE=https://google.serper.dev

# Image generation
NANOBANANA_API_KEY=INSERT_YOUR_NANOBANANA_API_KEY_HERE
NANOBANANA_API_URL=https://api.nanobanana.ai/v1/images/generate

# Runtime
PORT=8080
CACHE_TTL_MS=1800000
FETCH_TIMEOUT_MS=20000
MAX_CANDIDATES=45
